# ── REQUIRED SERVICES (Essential for startup and blog pipeline) ──────────────

# Groq (Primary content generation - blogs, LinkedIn, newsletter)
# Get key: https://console.groq.com
# Usage/Limits: Free tier rate limits apply.
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM (Primary regulatory and Tier 1 generation)
# Get key: https://build.nvidia.com
# Usage/Limits: Uses integrate.api.nvidia.com. Free credits on registration.
NVIDIA_API_KEY=replace_me
NVIDIA_MODEL_BLOG=mistralai/mistral-medium-3.5-128b
NVIDIA_MODEL_ANALYTICAL=qwen/qwen3-5-122b-a10b
NVIDIA_MODEL_FAST=deepseek-ai/deepseek-v4-flash

# Tavily (Real-time news search / competitor search fallback)
# Get key: https://tavily.com
# Usage/Limits: Free tier offers 1,000 queries per month.
TAVILY_API_KEY=replace_me

# Serper.dev (SERP intelligence + Google rank tracking)
# Get key: https://serper.dev
# Usage/Limits: Free tier offers 2,500 queries on signup.
SERPER_API_KEY=replace_me


# ── ACTIVE INTEGRATIONS (Degrade gracefully if keys are missing) ─────────────

# Google Search Console + Web Search Indexing API Credentials JSON key path.
# Usage/Limits: Service account email must be added as Owner in Search Console settings.
GSC_SERVICE_ACCOUNT_FILE=config/gsc_service_account.json
GSC_SITE_URL=sc-domain:kensara.in

# AllToken API (GPT, Claude GEO visibility monitoring)
# Usage/Limits: Standard OpenAI base URL fallback. Mocked responses used if key is missing.
ALLTOKEN_API_KEY=replace_me
ALLTOKEN_BASE_URL=https://api.openai.com/v1

# Perplexity API (Perplexity GEO visibility monitoring)
# Get key: https://www.perplexity.ai/settings/api
# Usage/Limits: Mocked responses used if key is missing.
PERPLEXITY_API_KEY=replace_me

# Gemini API Key (Direct Gemini GEO visibility monitoring)
# Get key: https://aistudio.google.com/
# Usage/Limits: Free tier allows 15 requests per minute for Gemini 1.5 Flash. Mocked responses used if key is missing.
GEMINI_API_KEY=replace_me


# ── OPTIONAL & FUTURE MODULES (Phase 2) ──────────────────────────────────────

# WordPress (Kensara blog publishing integration)
WORDPRESS_URL=https://kensara.in
WORDPRESS_USER=replace_me
WORDPRESS_APP_PASSWORD=replace_me

# LinkedIn (LinkedIn post publisher)
LINKEDIN_CLIENT_ID=replace_me
LINKEDIN_CLIENT_SECRET=replace_me
LINKEDIN_ACCESS_TOKEN=replace_me
LINKEDIN_ORGANIZATION_ID=replace_me

# Mailchimp (Newsletter campaign triggers)
MAILCHIMP_API_KEY=replace_me
MAILCHIMP_LIST_ID=replace_me


# ── SYSTEM CONFIGURATION ──────────────────────────────────────────────────────
CONTENT_OUTPUT_DIR=drafts
BLOG_CADENCE=daily
TZ=Asia/Kolkata
INTEGRATION_TEST=false
