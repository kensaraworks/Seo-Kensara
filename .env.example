# KensaraAI SEO Agent — Environment Variables
# Copy to .env and fill real values. Never commit .env.

# ── Azure OpenAI (news scoring only — complex JSON) ───────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_KEY=replace_me
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Groq (PRIMARY content gen — blogs, LinkedIn, newsletter — FREE) ────────
# Get key: https://console.groq.com
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# ── NVIDIA NIM (PRIMARY content generation — FREE) ────────────────────────
# Get key: https://build.nvidia.com  |  Base URL: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=replace_me
# Blog/long-form SEO content
NVIDIA_MODEL_BLOG=mistralai/mistral-medium-3.5-128b
# Analytical/comparison posts (DPDPA vs GDPR)
NVIDIA_MODEL_ANALYTICAL=qwen/qwen3-5-122b-a10b
# Fast drafts — LinkedIn posts, newsletter bullets
NVIDIA_MODEL_FAST=deepseek-ai/deepseek-v4-flash

# ── Tavily (real-time news — 1000 credits/month FREE) ─────────────────────
# Get key: https://tavily.com
TAVILY_API_KEY=replace_me

# ── Serper.dev (Google rank tracking — 2500 queries FREE) ─────────────────
# Get key: https://serper.dev
SERPER_API_KEY=replace_me

# ── WordPress (kensara.in) ─────────────────────────────────────────────────
WORDPRESS_URL=https://kensara.in
WORDPRESS_USER=replace_me
WORDPRESS_APP_PASSWORD=replace_me  # WP Admin > Users > Profile > Application Passwords

# ── LinkedIn ───────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=replace_me
LINKEDIN_CLIENT_SECRET=replace_me
LINKEDIN_ACCESS_TOKEN=replace_me  # OAuth2 bearer, valid 60 days
LINKEDIN_ORGANIZATION_ID=replace_me  # Company page ID

# ── Mailchimp (newsletter — free up to 500 contacts) ──────────────────────
MAILCHIMP_API_KEY=replace_me
MAILCHIMP_LIST_ID=replace_me

# ── Content Settings ───────────────────────────────────────────────────────
CONTENT_OUTPUT_DIR=drafts
BLOG_CADENCE=daily
TZ=Asia/Kolkata

# ── Dev flags ─────────────────────────────────────────────────────────────
INTEGRATION_TEST=false
